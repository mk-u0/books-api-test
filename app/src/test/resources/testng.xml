<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Google Books API Test Suite" verbose="1" thread-count="1">

    <test name="Public Read Endpoints" preserve-order="true">
        <classes>
            <class name="books.api.tests.UsersBookshelvesTest" />
           <class name="books.api.tests.VolumesTest" />
       </classes>
    </test>

    <test name="My Library Endpoints" preserve-order="true">
        <classes>
            <class name="books.api.tests.MyLibraryBookshelvesTest" />
            <class name="books.api.tests.MyLibraryActionsTest" />
        </classes>
    </test>

</suite>
